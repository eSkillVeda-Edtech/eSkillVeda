<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @page { 
      size: A4;
      margin: 1cm; 
    }
    * {
      box-sizing: border-box;
    }
    body { 
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; 
      font-size: 10pt;
      line-height: 1.5;
      color: #333; 
      margin: 0; 
      padding: 15px; 
      background: #fff;
    }
    .container {
      max-width: 100%;
      margin: 0 auto;
    }
    h1 { 
      font-size: 24pt; 
      font-weight: 300;
      margin: 0 0 5px 0; 
      color: #2c3e50;
      letter-spacing: -0.5px;
    }
    h2 { 
      font-size: 11pt;
      font-weight: 600;
      border-bottom: 1px solid #bdc3c7; 
      margin: 25px 0 10px 0; 
      padding-bottom: 5px;
      color: #34495e;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .header {
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 1px solid #ecf0f1;
    }
    .contact-info {
      font-size: 9pt;
      color: #7f8c8d;
      margin-top: 5px;
    }
    .contact-info a {
      color: #3498db;
      text-decoration: none;
    }
    .contact-info a:hover {
      text-decoration: underline;
    }
    .section { 
      margin-bottom: 25px; 
      break-inside: avoid;
    }
    p {
      margin: 5px 0;
      line-height: 1.6;
    }
    ul {
      padding-left: 18px;
      margin: 8px 0 12px 0;
    }
    ul li {
      margin: 3px 0;
      line-height: 1.5;
    }
    .skills-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      list-style: none;
      padding: 0;
      margin: 10px 0;
      justify-content: center;
      align-items: center;
    }
    .skills-grid li {
      padding: 4px 8px;
      border: 1px solid #ecf0f1;
      text-align: center;
      font-size: 9pt;
      color: #34495e;
      background: #f8f9fa;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .job-section {
      margin-bottom: 15px;
    }
    .job-title {
      font-weight: 600;
      color: #2c3e50;
      font-size: 11pt;
    }
    .company-duration {
      color: #7f8c8d;
      font-size: 9pt;
      margin: 2px 0 6px 0;
    }
    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 5px;
      flex-wrap: wrap;
    }
    .project-name {
      font-weight: 600;
      color: #2c3e50;
    }
    .project-year {
      color: #7f8c8d;
      font-size: 9pt;
    }
    .education-item {
      margin-bottom: 8px;
    }
    .degree {
      font-weight: 600;
      color: #2c3e50;
    }
    .institute-year {
      color: #7f8c8d;
      font-size: 9pt;
    }
    @media print {
      body {
        padding: 0;
      }
      .skills-grid, .skills {
        justify-content: flex-start;
        gap: 4px 6px !important;
      }
      .skills-grid li, .skills li {
        padding: 4px 8px !important;
        font-size: 8pt !important;
      }
      .section {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>{{ Contact.Name }}</h1>
      <div class="contact-info">
        {{ Contact.Email }} | {{ Contact.Phone }} | <a href="{{ Contact.LinkedIn }}">LinkedIn</a>
      </div>
    </div>

    {% if Summary %}
    <div class="section">
      <h2>Summary</h2>
      {% for s in Summary %}
      <p>{{ s }}</p>
      {% endfor %}
    </div>
    {% endif %}

    {% if Skills %}
    <div class="section">
      <h2>Skills</h2>
      <ul class="skills-grid">
         {% for skill in Skills %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if Experience %}
    <div class="section">
      <h2>Experience</h2>
      {% for exp in Experience %}
        <div class="job-section">
          <div class="job-title">{{ exp.Role }}</div>
           <div class="company-duration">{{ exp.Company }} | {{ exp.Duration }}</div>
          <ul>
            {% for d in exp.Description %}
            <li>{{ d }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if Projects %}
    <div class="section">
      <h2>Projects</h2>
      {% for p in Projects %}
        <div class="project-header">
          <span class="project-name">{{ p.Name }}</span>
          <span class="project-year">{{ p.Year }}</span>
        </div>
        {% if p.Description is iterable and p.Description is not string %}
          <ul>
          {% for point in p.Description %}
            <li>{{ point }}</li>
          {% endfor %}
          </ul>
        {% else %}
          <p>{{ p.Description }}</p>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% if Education %}
    <div class="section">
      <h2>Education</h2>
      {% for e in Education %}
        <div class="education-item">
          <div class="degree">{{ e.Degree }}</div>
          <div class="institute-year">{{ e.Institute }} | {{ e.Year }}</div>
        </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if Certification %}
    <div class="section">
      <h2>Certifications</h2>
      <ul>
        {% for c in Certification %}
        <li>{{ c }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
</body>
</html>