<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @page { 
      size: A4;
      margin: 0.8cm;
    }
    * {
      box-sizing: border-box;
    }
    body { 
      font-family: 'Times New Roman', Georgia, serif; 
      font-size: 10pt;
      line-height: 1.5;
      margin: 0; 
      padding: 20px; 
      color: #2c3e50;
      background: #fff;
    }
    .container {
      max-width: 100%;
      margin: 0 auto;
    }
    h1 { 
      font-size: 20pt; 
      font-weight: 700;
      margin: 0 0 10px 0;
      text-align: center;
      color: #2c3e50;
      letter-spacing: 1px;
      border-bottom: 3px double #2c3e50;
      padding-bottom: 10px;
    }
    h2 { 
      font-size: 12pt; 
      font-weight: 600;
      border-bottom: 2px solid #34495e;
      margin: 18px 0 10px 0;
      padding-bottom: 3px;
      color: #2c3e50;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .header {
      text-align: center;
      margin-bottom: 25px;
      padding-bottom: 15px;
    }
    .contact-info {
      font-size: 10pt;
      color: #34495e;
      margin-top: 8px;
      font-style: italic;
    }
    .contact-info a {
      color: #2c3e50;
      text-decoration: none;
      border-bottom: 1px dotted #2c3e50;
    }
    .contact-info a:hover {
      border-bottom-style: solid;
    }
    p, li { 
      margin: 4px 0; 
      line-height: 1.6;
    }
    ul { 
      padding-left: 20px; 
      margin: 8px 0 15px 0;
    }
    .section {
      margin-bottom: 20px;
      break-inside: avoid;
    }
    .skills-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      list-style: none;
      padding: 0;
      margin: 10px 0;
      justify-content: center;
      align-items: center;
    }
    .skills-grid li {
      padding: 5px 10px;
      border: 1px solid #bdc3c7;
      text-align: center;
      font-size: 9pt;
      background: #ecf0f1;
      font-weight: 500;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .job-header {
      margin-bottom: 6px;
    }
    .job-title {
      font-weight: 700;
      color: #2c3e50;
      font-size: 11pt;
    }
    .company-duration {
      color: #7f8c8d;
      font-size: 9pt;
      font-style: italic;
      margin-top: 2px;
    }
    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 5px;
      flex-wrap: wrap;
    }
    .project-name {
      font-weight: 700;
      color: #2c3e50;
    }
    .project-year {
      color: #7f8c8d;
      font-size: 9pt;
      font-style: italic;
    }
    .education-item {
      margin-bottom: 8px;
    }
    .degree {
      font-weight: 700;
      color: #2c3e50;
    }
    .institute-year {
      color: #7f8c8d;
      font-size: 9pt;
      font-style: italic;
    }
    @media print {
      body {
        padding: 0;
      }
      .skills-grid, .skills {
        justify-content: flex-start;
        gap: 4px 6px !important;
      }
      .skills-grid li, .skills li {
        padding: 4px 8px !important;
        font-size: 8pt !important;
      }
      .section {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>{{ Contact.Name }}</h1>
      <div class="contact-info">
        {{ Contact.Email }} | {{ Contact.Phone }} | <a href="{{ Contact.LinkedIn }}">LinkedIn Profile</a>
      </div>
    </div>

    {% if Summary %}
    <div class="section">
      <h2>Professional Summary</h2>
      {% for line in Summary %}
      <p>{{ line }}</p>
      {% endfor %}
    </div>
    {% endif %}

    {% if Skills %}
    <div class="section">
      <h2>Core Competencies</h2>
      <ul class="skills-grid">
        {% for skill in Skills %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if Experience %}
    <div class="section">
      <h2>Professional Experience</h2>
      {% for job in Experience %}
        <div class="job-header">
          <div class="job-title">{{ job.Role }}</div>
          <div class="company-duration">{{ job.Company }} | {{ job.Duration }}</div>
        </div>
        <ul>
          {% for d in job.Description %}
          <li>{{ d }}</li>
          {% endfor %}
        </ul>
      {% endfor %}
    </div>
    {% endif %}

    {% if Projects %}
    <div class="section">
       <h2>Notable Projects</h2>
      {% for p in Projects %}
        <div class="project-header">
          <span class="project-name">{{ p.Name }}</span>
          <span class="project-year">{{ p.Year }}</span>
        </div>
        {% if p.Description is iterable and p.Description is not string %}
          <ul>
            {% for point in p.Description %}
              <li>{{ point }}</li>
            {% endfor %}
          </ul>
        {% else %}
          <p>{{ p.Description }}</p>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% if Education %}
    <div class="section">
       <h2>Education</h2>
      {% for e in Education %}
        <div class="education-item">
          <div class="degree">{{ e.Degree }}</div>
          <div class="institute-year">{{ e.Institute }} | {{ e.Year }}</div>
        </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if Certification %}
    <div class="section">
      <h2>Professional Certifications</h2>
      <ul>
        {% for c in Certification %}
        <li>{{ c }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
</body>
</html>