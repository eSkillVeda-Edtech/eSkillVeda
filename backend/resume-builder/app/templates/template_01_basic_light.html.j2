<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @page {
      size: A4;
      margin: 0.8cm;
    }
    * {
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      font-size: 10pt;
      line-height: 1.4;
      margin: 0;
      padding: 15px;
      color: #333;
      background: #fff;
    }
    .container {
      max-width: 100%;
      margin: 0 auto;
    }
    h1 {
      font-size: 18pt;
      font-weight: 600;
      margin: 0 0 8px 0;
      color: #2c3e50;
      letter-spacing: 0.5px;
    }
    h2 {
      font-size: 11pt;
      font-weight: 600;
      color: #34495e;
      border-bottom: 2px solid #3498db;
      margin: 15px 0 8px 0;
      padding-bottom: 3px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }
    p {
      margin: 3px 0 6px 0;
      line-height: 1.5;
    }
    .header {
      text-align: center;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 1px solid #ecf0f1;
    }
    .contact-info {
      font-size: 9pt;
      color: #7f8c8d;
      margin-top: 5px;
    }
    .contact-info a {
      color: #3498db;
      text-decoration: none;
    }
    .section {
      margin-bottom: 18px;
      break-inside: avoid;
    }
    ul {
      margin: 6px 0 12px 0;
      padding-left: 18px;
    }
    ul li {
      margin: 3px 0;
      line-height: 1.4;
    }
        .skills-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      list-style: none;
      padding: 0;
      margin: 10px 0;
      justify-content: center;
      align-items: center;
    }
    .skills-grid li {
      background: #ecf0f1;
      padding: 4px 8px;
      border-radius: 3px;
      font-size: 9pt;
      text-align: center;
      border-left: 3px solid #3498db;
          white-space: nowrap;
      flex-shrink: 0;
      text-align: center;
    }
    .job-title {
      font-weight: 600;
      color: #2c3e50;
      margin-bottom: 2px;
    }
    .company-duration {
      font-size: 9pt;
      color: #7f8c8d;
      margin-bottom: 5px;
    }
    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 3px;
    }
    .project-name {
      font-weight: 600;
      color: #2c3e50;
    }
    .project-year {
      font-size: 9pt;
      color: #7f8c8d;
    }
    .education-item {
      margin-bottom: 8px;
    }
    .degree {
      font-weight: 600;
      color: #2c3e50;
    }
    .institute {
      color: #7f8c8d;
      font-size: 9pt;
    }
    @media print {
      body {
        padding: 0;
      
      .skills-grid, .skills {
        justify-content: flex-start;
        gap: 4px 6px !important;
      }
      .skills-grid li, .skills li {
        padding: 4px 8px !important;
        font-size: 8pt !important;
      }}
      .section {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>{{ Contact.Name }}</h1>
      <div class="contact-info">
        {{ Contact.Email }} | {{ Contact.Phone }} | <a href="{{ Contact.LinkedIn }}">LinkedIn</a>
      </div>
    </div>

    {% if Summary %}
    <div class="section">
      <h2>Summary</h2>
      {% for line in Summary %}
      <p>{{ line }}</p>
      {% endfor %}
    </div>
    {% endif %}

    {% if Skills %}
    <div class="section">
      <h2>Skills & Expertise</h2>
      <ul class="skills-grid">
        {% for skill in Skills %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if Experience %}
    <div class="section">
      <h2>Experience</h2>
      {% for exp in Experience %}
        <div class="job-title">{{ exp.Role }}</div>
        <div class="company-duration">{{ exp.Company }} | {{ exp.Duration }}</div>
        <ul>
          {% for d in exp.Description %}
          <li>{{ d }}</li>
          {% endfor %}
        </ul>
      {% endfor %}
    </div>
    {% endif %}

    {% if Projects %}
<div class="section">
  <h2>Projects</h2>
  {% for p in Projects %}
    <div class="project-header">
      <span class="project-name">{{ p.Name }}</span>
    </div>
    {% if p.Description is iterable and p.Description is not string %}
      <ul>
        {% for point in p.Description %}
          <li>{{ point }}</li>
        {% endfor %}
      </ul>
    {% else %}
      <p>{{ p.Description }}</p>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

    {% if Education %}
    <div class="section">
      <h2>Education</h2>
      {% for edu in Education %}
        <div class="education-item">
          <div class="degree">{{ edu.Degree }}</div>
          <div class="institute">{{ edu.Institute }} | {{ edu.Year }}</div>
        </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if Certification %}
    <div class="section">
      <h2>Certifications</h2>
      <ul>
        {% for cert in Certification %}
        <li>{{ cert }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
</body>
</html>