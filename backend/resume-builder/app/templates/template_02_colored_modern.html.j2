<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @page { 
      size: A4;
      margin: 0.8cm;
    }
    * {
      box-sizing: border-box;
    }
    body { 
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      font-size: 10pt;
      line-height: 1.5;
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); 
      color: #2c3e50; 
      margin: 0;
      padding: 20px;
    }
    .container {
      background: #ffffff;
      padding: 25px;
      border-radius: 8px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      max-width: 100%;
    }
    h1 { 
      font-size: 20pt; 
      font-weight: 700;
      margin: 0 0 10px 0;
      color: #1a5276; 
      text-align: center;
      letter-spacing: 1px;
    }
    h2 { 
      font-size: 12pt; 
      font-weight: 600;
      background: linear-gradient(90deg, #1a5276, #2980b9);
      color: white;
      padding: 8px 15px;
      margin: 18px 0 10px 0; 
      border-radius: 5px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }
    .header {
      text-align: center;
      margin-bottom: 25px;
      padding-bottom: 20px;
      border-bottom: 3px solid #1a5276;
    }
    .contact-info {
      font-size: 10pt;
      color: #34495e;
      margin-top: 8px;
    }
    .contact-info a { 
      color: #2980b9; 
      text-decoration: none;
      font-weight: 500;
    }
    .contact-info a:hover {
      text-decoration: underline;
    }
    p, li { 
      margin: 4px 0; 
      line-height: 1.6;
    }
    ul { 
      padding-left: 20px; 
      margin: 8px 0 15px 0;
    }
    ul li {
      margin: 5px 0;
    }
    .skills-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      list-style: none;
      padding: 0;
      margin: 10px 0;
      justify-content: center;
      align-items: center;
    }
    .skills-grid li {
      background: linear-gradient(135deg, #e8f4fd, #d6eaf8);
      border: 1px solid #aed6f1;
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 9pt;
      font-weight: 500;
      color: #1a5276;
      white-space: nowrap;
      flex-shrink: 0;
      text-align: center;
    }
    .section {
      margin-bottom: 20px;
      break-inside: avoid;
    }
    .job-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 5px;
      flex-wrap: wrap;
    }
    .job-title {
      font-weight: 600;
      color: #1a5276;
      font-size: 11pt;
    }
    .company {
      color: #34495e;
      font-weight: 500;
    }
    .duration {
      color: #7f8c8d;
      font-size: 9pt;
      font-style: italic;
    }
    .project-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 5px;
    }
    .project-name {
      font-weight: 600;
      color: #1a5276;
    }
    .project-year {
      color: #7f8c8d;
      font-size: 9pt;
    }
    .education-item {
      margin-bottom: 10px;
    }
    .degree {
      font-weight: 600;
      color: #1a5276;
    }
    .institute-year {
      color: #34495e;
      font-size: 9pt;
    }
    @media print {
      body {
        background: white;
        padding: 0;
      }
      .skills-grid, .skills {
        justify-content: flex-start;
        gap: 4px 6px !important;
      }
      .skills-grid li, .skills li {
        padding: 4px 8px !important;
        font-size: 8pt !important;
      }
      .container {
        box-shadow: none;
        border-radius: 0;
        padding: 15px;
      }
      .section {
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>{{ Contact.Name }}</h1>
      <div class="contact-info">
        {{ Contact.Email }} | {{ Contact.Phone }} | <a href="{{ Contact.LinkedIn }}">LinkedIn Profile</a>
      </div>
    </div>

    {% if Summary %}
    <div class="section">
      <h2>Professional Summary</h2>
      {% for line in Summary %}
      <p>{{ line }}</p>
      {% endfor %}
    </div>
    {% endif %}

    {% if Skills %}
    <div class="section">
      <h2>Technical Skills</h2>
      <ul class="skills-grid">
        {% for skill in Skills %}
        <li>{{ skill }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if Experience %}
    <div class="section">
      <h2>Professional Experience</h2>
      {% for job in Experience %}
        <div class="job-header">
          <div>
            <div class="job-title">{{ job.Role }}</div>
            <div class="company">{{ job.Company }}</div>
          </div>
          <div class="duration">{{ job.Duration }}</div>
        </div>
        <ul>
          {% for d in job.Description %}
          <li>{{ d }}</li>
          {% endfor %}
        </ul>
      {% endfor %}
    </div>
    {% endif %}

    {% if Projects %}
    <div class="section">
      <h2>Notable Projects</h2>
      {% for p in Projects %}
        <div class="project-header">
          <span class="project-name">{{ p.Name }}</span>
          <span class="project-year">{{ p.Year }}</span>
        </div>
        {% if p.Description is iterable and p.Description is not string %}
          <ul>
            {% for point in p.Description %}
              <li>{{ point }}</li>
            {% endfor %}
          </ul>
        {% else %}
          <p>{{ p.Description }}</p>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {% if Education %}
    <div class="section">
      <h2>Education</h2>
      {% for e in Education %}
        <div class="education-item">
          <div class="degree">{{ e.Degree }}</div>
          <div class="institute-year">{{ e.Institute }} | {{ e.Year }}</div>
        </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if Certification %}
    <div class="section">
      <h2>Certifications</h2>
      <ul>
        {% for c in Certification %}
        <li>{{ c }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
</body>
</html>