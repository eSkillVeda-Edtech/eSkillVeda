<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        /* General Styles */
        @page {
            size: A4;
            margin: 0;
        }
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }
        body {
            display: flex;
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            font-size: 11pt;
            font-weight: 600;
            line-height: 1.5;
            background: #ffffff;
            color: #2c3e50;
        }
        
        /* Two-column Layout */
        .left {
            width: 30%;
            background: #ffffff;
            color: #2c3e50;
            padding: 16px;
            min-height: 100vh;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            /* Added divider */
            border-right: 1px solid #bdc3c7;
            margin-right: 10px;
        }
        .right {
            width: 70%;
            padding: 16px;
            background: #ffffff;
            color: #2c3e50;
            min-height: 100vh;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
        }
        
        /* Typography - Common */
        h1 {
            font-size: 18pt;
            font-weight: 600;
            margin-bottom: 5px;
            color: #2c3e50;
        }
        h2 {
            font-size: 11pt;
            font-weight: 600;
            color: #3498db;
            border-bottom: 2px solid #3498db;
            padding-bottom: 3px;
            margin: 10px 0 4px;
        }
        h3 {
            font-size: 11pt;
            font-weight: 600;
            color: #3498db;
            margin: 8px 0 4px;
        }
        ul {
            padding-left: 16px;
            margin: 4px 0 8px;
        }
        .skills-grid {
            list-style: none;
            padding: 0;
        }
        a {
            color: #3498db;
        }
    
        * {
            box-sizing: border-box;
        }
        .section {
            margin-bottom: 20px;
            break-inside: avoid;
        }
        .job-header {
            margin-bottom: 8px;
        }
        .job-title {
            font-weight: 600;
            color: #2c3e50;
            font-size: 11pt;
        }
        .company-duration {
            color: #7f8c8d;
            font-size: 9pt;
            margin-top: 2px;
        }
        .project-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 5px;
            flex-wrap: wrap;
        }
        .project-name {
            font-weight: 600;
            color: #2c3e50;
        }
        .project-year {
            color: #7f8c8d;
            font-size: 9pt;
        }
        .education-item {
            margin-bottom: 10px;
        }
        .degree {
            font-weight: 600;
            color: #2c3e50;
        }
        .institute-year {
            color: #7f8c8d;
            font-size: 9pt;
        }
        
        /* Print Media Queries */
        @media print {
            body {
                padding: 0;
            }
            .skills-grid, .skills {
                justify-content: flex-start;
                gap: 4px 6px !important;
            }
            .skills-grid li, .skills li {
                padding: 4px 8px !important;
                font-size: 8pt !important;
            }
            .section {
                page-break-inside: avoid;
            }
        }
    </style>
</head>
<body>
    <div class="left">
        <h1>{{ Contact.Name }}</h1>
        <p>{{ Contact.Email }}<br>{{ Contact.Phone }}<br><a href="{{ Contact.LinkedIn }}">LinkedIn</a></p>
        {% if Skills %}<h3>Skills</h3><ul class="skills-grid">{% for skill in Skills %}<li>{{ skill }}</li>{% endfor %}</ul>{% endif %}
        {% if Certification %}<h3>Certifications</h3><ul>{% for c in Certification %}<li>{{ c }}</li>{% endfor %}</ul>{% endif %}
    </div>
    <div class="right">
        {% if Summary %}<h2>Summary</h2>{% for s in Summary %}<p>{{ s }}</p>{% endfor %}{% endif %}
        {% if Experience %}<h2>Experience</h2>
          {% for e in Experience %}
            <div class="job-header">
                <div class="job-title">{{ e.Role }}</div>
                <div class="company-duration">{{ e.Company }} | {{ e.Duration }}</div>
            </div>
            <ul>
                {% for d in e.Description %}<li>{{ d }}</li>{% endfor %}
            </ul>
          {% endfor %}
        {% endif %}
        {% if Projects %}<h2>Projects</h2>
          {% for p in Projects %}
            <div class="project-header">
              <span class="project-name">{{ p.Name }}</span>
              <span class="project-year">{{ p.Year }}</span>
            </div>
            {% if p.Description is iterable and p.Description is not string %}
              <ul>
                {% for point in p.Description %}
                  <li>{{ point }}</li>
                {% endfor %}
              </ul>
            {% else %}
              <p>{{ p.Description }}</p>
            {% endif %}
          {% endfor %}
        {% endif %}
        {% if Education %}<h2>Education</h2>
            {% for e in Education %}
                <div class="education-item">
                    <div class="degree">{{ e.Degree }}</div>
                    <div class="institute-year">{{ e.Institute }} | {{ e.Year }}</div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</body>
</html>