<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resume</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        @page { size: A4; margin: 0; }
        body {
            font-family: 'Roboto', sans-serif;
            font-size: 11pt;
            line-height: 1.5;
            margin: 0;
            background: #fff8e1;
        }
        .top-strip {
            background: #ffc107;
            padding: 20px 32px;
            color: #2c3e50;
        }
        .top-strip h1 {
            margin: 0;
            font-size: 24pt;
            font-weight: 700;
        }
        .top-strip p {
            margin: 4px 0 0;
            line-height: 1.6;
            font-size: 10pt;
            color: #555;
        }
        .top-strip a {
            color: #2c3e50;
            text-decoration: underline;
        }
        .content {
            padding: 16px 32px;
        }
        h2 {
            font-size: 12pt;
            font-weight: 700;
            color: #2c3e50;
            margin-top: 20px;
            border-bottom: 2px solid #ffb300;
            padding-bottom: 4px;
        }
        .skills-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            list-style: none;
            padding: 0;
            margin: 10px 0;
        }
        .skills-grid li {
            background-color: #fff9c4;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 9pt;
            font-weight: 500;
            color: #444;
            white-space: nowrap;
        }
        .section {
            margin-bottom: 20px;
            page-break-inside: avoid;
        }
        .job-header { margin-bottom: 8px; }
        .job-title, .project-name, .degree {
            font-weight: 700;
            color: #2c3e50;
            font-size: 11pt;
        }
        .company-duration, .project-year, .institute-year {
            color: #7f8c8d;
            font-size: 9pt;
            margin-top: 2px;
        }
        ul {
            margin: 0;
            padding-left: 20px;
        }
        ul li {
            margin-bottom: 4px;
            font-size: 10pt;
            font-weight: 400;
        }
        * { box-sizing: border-box; }

        @media print {
            body { padding: 0; }
            .skills-grid, .skills {
                justify-content: flex-start;
                gap: 4px 6px !important;
            }
            .skills-grid li, .skills li {
                padding: 4px 8px !important;
                font-size: 8pt !important;
            }
            .section { page-break-inside: avoid; }
        }
    </style>
</head>
<body>
    <div class="top-strip">
        <h1>{{ Contact.Name }}</h1>
        <p>{{ Contact.Email }} | {{ Contact.Phone }} | <a href="{{ Contact.LinkedIn }}">LinkedIn</a></p>
    </div>
    <div class="content">
        {% if Summary %}
        <div class="section">
            <h2>Summary</h2>
            {% for s in Summary %}<p style="font-weight: 400; margin-bottom: 8px;">{{ s }}</p>{% endfor %}
        </div>
        {% endif %}

        {% if Skills %}
        <div class="section">
            <h2>Skills</h2>
            <ul class="skills-grid">{% for skill in Skills %}<li>{{ skill }}</li>{% endfor %}</ul>
        </div>
        {% endif %}

        {% if Experience %}
        <div class="section">
            <h2>Experience</h2>
            {% for e in Experience %}
            <div class="job-header">
                <div class="job-title">{{ e.Role }}</div>
                <div class="company-duration">{{ e.Company }} | {{ e.Duration }}</div>
            </div>
            <ul>
                {% for d in e.Description %}<li>{{ d }}</li>{% endfor %}
            </ul>
            {% endfor %}
        </div>
        {% endif %}

        {% if Projects %}
        <div class="section">
            <h2>Projects</h2>
            {% for p in Projects %}
            <div class="project-header">
                <span class="project-name">{{ p.Name }}</span>
                <span class="project-year">{{ p.Year }}</span>
            </div>
            {% if p.Description is iterable and p.Description is not string %}
            <ul>
                {% for point in p.Description %}
                <li>{{ point }}</li>
                {% endfor %}
            </ul>
            {% else %}
            <p style="font-weight: 400;">{{ p.Description }}</p>
            {% endif %}
            {% endfor %}
        </div>
        {% endif %}

        {% if Education %}
        <div class="section">
            <h2>Education</h2>
            {% for e in Education %}
            <div class="education-item">
                <div class="degree">{{ e.Degree }}</div>
                <div class="institute-year">{{ e.Institute }} | {{ e.Year }}</div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if Certification %}
        <div class="section">
            <h2>Certifications</h2>
            <ul>
                {% for c in Certification %}<li>{{ c }}</li>{% endfor %}
            </ul>
        </div>
        {% endif %}
    </div>
</body>
</html>